{
  "templates": [
    {
      "name": "homepage",
      "urls": [
        "https://www.academy.com/"
      ],
      "description": "Academy Sports + Outdoors homepage - full content with hero carousel, product carousels, promotional banners, brand showcases, and benefit cards",
      "blocks": [
        {
          "name": "hero",
          "instances": [
            "[data-testid='heroCarousel'], [class*='heroCarousel']",
            "[class*='halfBanner']:has(a[href*='baseball'])"
          ]
        },
        {
          "name": "cards",
          "instances": [
            "[class*='productCarousel']:nth-of-type(1)",
            "[class*='productCarousel']:nth-of-type(2)",
            "[class*='productCarousel']:nth-of-type(3)",
            "[class*='productCarousel']:nth-of-type(4)",
            "[class*='brandCarousel']:has(a[href*='running'])",
            "[class*='cardGrid']:has(a[href*='casual-shoes'])",
            "[class*='brandLogos']:has(img[alt*='Brazos'])",
            "[class*='serviceFeatures']:has(h3)"
          ]
        },
        {
          "name": "columns",
          "instances": [
            "[class*='twoCards']:has(a[href*='ariat'])",
            "[class*='twoCards']:has(a[href*='mlb'])",
            "[class*='threeCol']:has(img[alt='Academy Sports'])"
          ]
        }
      ],
      "sections": [
        {
          "id": "S1",
          "name": "Buy More Save More Promo Banner",
          "selector": "[aria-label*='Buy More']",
          "style": null,
          "blocks": [],
          "defaultContent": ["[aria-label*='Buy More'] a"]
        },
        {
          "id": "S2",
          "name": "Hero Carousel + Credit Card Promo",
          "selector": "[aria-label*='Buy More'] ~ div:has([class*='heroCarousel'])",
          "style": null,
          "blocks": ["hero"],
          "defaultContent": ["a[href*='myacademy-rewards-credit-card']"]
        },
        {
          "id": "S3",
          "name": "Today's Styles Product Carousel",
          "selector": "[class*='productCarousel']:has(h2:text('Today'))",
          "style": null,
          "blocks": ["cards"],
          "defaultContent": []
        },
        {
          "id": "S4",
          "name": "Top Shoes Product Carousel",
          "selector": "[class*='productCarousel']:has(h2:text('Top Shoes'))",
          "style": null,
          "blocks": ["cards"],
          "defaultContent": []
        },
        {
          "id": "S5",
          "name": "Outdoor Essentials Product Carousel",
          "selector": "[class*='productCarousel']:has(h2:text('Outdoor'))",
          "style": null,
          "blocks": ["cards"],
          "defaultContent": []
        },
        {
          "id": "S6",
          "name": "Home & Recreation Product Carousel",
          "selector": "[class*='productCarousel']:has(h2:text('Home'))",
          "style": null,
          "blocks": ["cards"],
          "defaultContent": []
        },
        {
          "id": "S7",
          "name": "Running Shoes Brand Showcase",
          "selector": "div:has(> a[href*='running-shoes'])",
          "style": null,
          "blocks": ["cards"],
          "defaultContent": ["a[href*='running-shoes'] > img"]
        },
        {
          "id": "S8",
          "name": "New Finds For You",
          "selector": "div:has(a[href*='casual-shoes'])",
          "style": null,
          "blocks": ["cards"],
          "defaultContent": []
        },
        {
          "id": "S9",
          "name": "Nike Soccer USA Banner",
          "selector": "div:has(a[href*='usa-soccer-gear'])",
          "style": null,
          "blocks": [],
          "defaultContent": ["a[href*='usa-soccer-gear']"]
        },
        {
          "id": "S10",
          "name": "Clearance Banner",
          "selector": "[aria-label*='Clearance']",
          "style": "yellow",
          "blocks": [],
          "defaultContent": ["[aria-label*='Clearance'] a"]
        },
        {
          "id": "S11",
          "name": "Baseball Section",
          "selector": "div:has(a[href*='/baseball'])",
          "style": null,
          "blocks": ["hero"],
          "defaultContent": []
        },
        {
          "id": "S12",
          "name": "Workwear Banner",
          "selector": "[aria-label*='workwear']",
          "style": "yellow",
          "blocks": [],
          "defaultContent": ["[aria-label*='workwear'] a"]
        },
        {
          "id": "S13",
          "name": "Workwear Brand Cards",
          "selector": "div:has(a[href*='ariat']):has(a[href*='carhartt'])",
          "style": null,
          "blocks": ["columns"],
          "defaultContent": []
        },
        {
          "id": "S14",
          "name": "Workwear Brand Logos",
          "selector": "div:has(h3:text('LOOKING FOR MORE BRANDS'))",
          "style": null,
          "blocks": ["cards"],
          "defaultContent": ["h3:text('LOOKING FOR MORE BRANDS')"]
        },
        {
          "id": "S15",
          "name": "Trending For Fans",
          "selector": "div:has(a[href*='mlb']):has(a[href*='ncaa'])",
          "style": null,
          "blocks": ["columns"],
          "defaultContent": []
        },
        {
          "id": "S16",
          "name": "More Savings More Fun",
          "selector": "div:has(h2:text('More Savings'))",
          "style": null,
          "blocks": [],
          "defaultContent": ["h2:text('More Savings')", "a[href*='myacademy-rewards'] img"]
        },
        {
          "id": "S17",
          "name": "App + Price Match + SMS Signup",
          "selector": "div:has(img[alt='Academy Sports']):has(img[alt*='Undefeatable'])",
          "style": null,
          "blocks": ["columns"],
          "defaultContent": []
        },
        {
          "id": "S18",
          "name": "Benefits Cards",
          "selector": "div:has(h3:text('$15 OFF'))",
          "style": "light-gray",
          "blocks": ["cards"],
          "defaultContent": []
        }
      ]
    }
  ]
}
